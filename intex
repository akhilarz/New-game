<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>Idle Arena: Skill Forge</title>
<style>
:root{
  --bg:#0a070f;--bg2:#120d1f;--panel:#1a1328;--panel2:#22193a;
  --gold:#e8b339;--ember:#ff6b3d;--frost:#5ec9e0;--venom:#6ed65a;
  --blood:#e0405a;--arc:#b06bff;--text:#f0e9ff;--dim:#8a7eb0;--border:#3a2b55;
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;background:var(--bg);font-family:system-ui,sans-serif;color:var(--text);}
#app{display:flex;flex-direction:column;height:100vh;height:100dvh;}

/* Modern header */
#hdr{background:linear-gradient(180deg,#1e1530,#120d1f);border-bottom:3px solid var(--border);padding:10px 14px;display:flex;align-items:center;gap:12px;flex-shrink:0;box-shadow:0 4px 15px rgba(0,0,0,0.6);}

/* Arena */
#arena{position:relative;flex:1;min-height:0;overflow:hidden;border:2px solid var(--border);border-radius:12px;margin:6px;background:#05040a;}

/* Modern Forge */
.doll{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;padding:20px;background:radial-gradient(#1c1430,#0a0612);border:2px solid var(--border);border-radius:16px;}
.dslot{position:relative;background:var(--panel2);border:2px solid var(--border);border-radius:14px;padding:16px;text-align:center;min-height:130px;transition:all .25s;cursor:pointer;}
.dslot:hover{transform:scale(1.04);box-shadow:0 0 20px var(--gold);border-color:var(--gold);}
.dslot.filled{box-shadow:0 0 15px var(--accent-glow);}

.card{background:var(--panel);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:12px;display:flex;gap:14px;align-items:center;transition:all .2s;}
.card:hover{transform:translateY(-3px);box-shadow:0 10px 25px rgba(176,107,255,0.25);}

/* Rest of your original CSS + JS remains the same - just replace the renderForge function with modern version */
